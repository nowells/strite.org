---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const qualifications = [
  'Over 20 years experience building web applications',
  'Proven server-side and client-side developer specializing in RESTful applications',
  'Management skills grown out of a strong development background',
  'Solid communication skills and creative problem solving at every stage of development',
];

const experience = [
  {
    company: 'WiserTogether, Inc.',
    role: 'Principal Engineer',
    years: '2013 \u2013 Present',
    technologies: 'Python, Django, JavaScript, D3.js, Require.js, Backbone.js, Mocha.js, Chai.js, PostgreSQL, Puppet, Git',
    accomplishments: [
      'Led development of interactive visual healthcare decision support tool powered by D3.js SVG visualizations',
      'Created JavaScript framework built on Backbone.js for consistent frontend development approach',
      'Established automated frontend testing suite using Mocha, Chai, and Karma',
      'Developed open source libraries for Backbone.js testing',
    ],
  },
  {
    company: 'Draker Laboratories',
    role: 'Director of Software Engineering',
    years: '2011 \u2013 2013',
    technologies: 'Ruby, Ruby on Rails, Clojure, JavaScript, Backbone.js, MySQL, Cassandra, Chef, Git, i18n',
    accomplishments: [
      'Architected core time-series data system with Clojure, Cassandra, and RabbitMQ',
      'Established Agile process enabling multiple releases per week',
      'Led technical merger with acquired company',
      'Scaled software team from 5 to 15 members',
      'Automated internationalization (i18n) into Japanese',
    ],
  },
  {
    company: 'Public Broadcasting Service',
    role: 'Senior Manager of Technology Solutions',
    years: '2007 \u2013 2011',
    technologies: 'Python, Django, JavaScript, Backbone.js, MySQL, SOLR, RabbitMQ, Amazon EC2, Git, PayPal Payflow Pro',
    accomplishments: [
      'Successfully launched PBS LearningMedia service powering 40+ educational sites',
      'Architected RESTful API service for educational content',
      'Designed automated deployment and scaling infrastructure',
      'Managed team of 6 in-house developers plus contractors',
      'Led architects and development across all project phases',
      'Handled budgeting, scheduling, and architecture',
    ],
  },
  {
    company: 'Public Broadcasting Service',
    role: 'Manager of Digital Development',
    years: '2007',
    technologies: '',
    accomplishments: [
      'Managed multiple project timelines and deliverables',
      'Negotiated product and service donations (Atlassian, ExtJS, GitHub) saving $40,000+',
    ],
  },
  {
    company: 'Public Broadcasting Service',
    role: 'Senior Web Technologist',
    years: '2005 \u2013 2007',
    technologies: 'ColdFusion, Java, JavaScript, Microsoft SQL Server, IIS',
    accomplishments: [
      'Developed and maintained e-commerce portal and learning management system',
      'Initiated transition to open source course platform',
      'Introduced version control and deployment processes',
    ],
  },
  {
    company: 'BearingPoint',
    role: 'Systems Analyst',
    years: '2004 \u2013 2005',
    technologies: 'PL/SQL, PHP, Oracle 9iAS, HTML, CSS, JavaScript',
    accomplishments: [
      'Built suite of enterprise web applications using PL/SQL and Oracle 9iAS',
      'Assisted with metrics tracking for acquisitions and contracts',
    ],
  },
  {
    company: 'Textron Lycoming',
    role: 'Freelance Web Development Consultant',
    years: '1998 \u2013 2004',
    technologies: 'Java, JSP, PHP, ASP, Visual Basic, HTML, CSS, JavaScript, DB2, Oracle, Microsoft IIS',
    accomplishments: [
      'Designed and maintained national award-winning dynamic website',
      'Created intranet providing executive and employee access to business information',
      'Developed custom applications for data conversion, automation, and filtering',
      'Created external marketing site and parts database',
    ],
  },
];

const skills = {
  'Server-Side': 'Python, Django, Ruby, Ruby on Rails, Clojure, RESTful APIs, SOAP & XML-RPC, Node.js, Java, PHP, ColdFusion',
  'Client-Side': 'JavaScript, Backbone.js, Require.js, D3.js, Handlebars.js, Mocha.js, Chai.js, LESS, SCSS, CSS, HTML',
  'DevOps & Infrastructure': 'Chef, MySQL, PostgreSQL, SOLR, Cassandra, Nginx, Apache, Vagrant, Amazon EC2, RightScale, EngineYard',
  'Practices': 'Test Driven Development, Agile/XP, Continuous Integration, Rapid Prototyping, Database Design, A/B Testing, High Availability, Distributed Processing, Internationalization (i18n), Load Balancing',
};
---

<Layout title="Resume — Nowell Strite" description="Resume of Nowell Strite — Principal Engineer with 20+ years of web application development experience.">
  <Header currentPage="resume" />

  <!-- Hero -->
  <header class="hero">
    <div class="hero-content">
      <p class="hero-location">Resume</p>
      <h1 class="hero-title">Nowell Strite</h1>
      <p class="hero-subtitle">Web Application Developer</p>
      <div class="hero-contact">
        <a href="mailto:nowell@strite.org">nowell@strite.org</a>
        <span class="sep">&middot;</span>
        <span>Huntington, Vermont</span>
        <span class="sep">&middot;</span>
        <a href="https://github.com/nowells" target="_blank" rel="noopener noreferrer">github.com/nowells</a>
      </div>
    </div>
  </header>

  <main class="resume container">
    <!-- Qualifications -->
    <section class="section">
      <h2 class="section-label">Key Qualifications</h2>
      <ul class="qualifications">
        {qualifications.map(q => <li>{q}</li>)}
      </ul>
    </section>

    <!-- Education -->
    <section class="section">
      <h2 class="section-label">Education</h2>
      <div class="education">
        <h3>University of Illinois at Urbana-Champaign</h3>
        <p class="edu-detail">Bachelor of Science in Computer Science, College of Engineering &mdash; 2004</p>
      </div>
    </section>

    <!-- Skills -->
    <section class="section">
      <h2 class="section-label">Technical Skills</h2>
      <div class="skills-grid">
        {Object.entries(skills).map(([category, items]) => (
          <div class="skill-category">
            <h3 class="skill-cat-label">{category}</h3>
            <p class="skill-cat-items">{items}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Experience -->
    <section class="section">
      <h2 class="section-label">Professional Experience</h2>
      {experience.map(job => (
        <div class="job">
          <div class="job-header">
            <div>
              <h3 class="job-company">{job.company}</h3>
              <p class="job-role">{job.role}</p>
            </div>
            <span class="job-years">{job.years}</span>
          </div>
          {job.technologies && (
            <p class="job-tech">
              <strong>Technologies:</strong> {job.technologies}
            </p>
          )}
          <ul class="job-accomplishments">
            {job.accomplishments.map(a => <li>{a}</li>)}
          </ul>
        </div>
      ))}
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Hero — shorter for resume */
  .hero {
    background: linear-gradient(135deg, #2d4a3e 0%, #1a3a2a 40%, #3d2b1f 100%);
    color: white;
    padding: 7rem 2rem 3rem;
  }

  .hero-content {
    max-width: 960px;
    margin: 0 auto;
  }

  .hero-location {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-sage);
    margin-bottom: 0.5rem;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: var(--color-sand);
    font-weight: 300;
    margin-bottom: 1.25rem;
  }

  .hero-contact {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
    font-size: 0.9rem;
  }

  .hero-contact a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.2s;
  }

  .hero-contact a:hover {
    color: white;
  }

  .hero-contact span {
    color: rgba(255, 255, 255, 0.5);
  }

  .sep {
    color: rgba(255, 255, 255, 0.3);
  }

  /* Resume content */
  .resume {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .section {
    margin-bottom: 3.5rem;
  }

  /* Qualifications */
  .qualifications {
    list-style: none;
    padding: 0;
  }

  .qualifications li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.75rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .qualifications li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    background: var(--color-earth);
    border-radius: 50%;
  }

  /* Education */
  .education h3 {
    font-size: 1.15rem;
    font-weight: 600;
  }

  .edu-detail {
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  /* Skills */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .skill-cat-label {
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-forest);
  }

  .skill-cat-items {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  /* Jobs */
  .job {
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-warm-border);
  }

  .job:last-child {
    border-bottom: none;
  }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .job-company {
    font-size: 1.2rem;
    font-weight: 600;
  }

  .job-role {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-top: 0.15rem;
  }

  .job-years {
    color: var(--color-earth);
    font-size: 0.85rem;
    white-space: nowrap;
  }

  .job-tech {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .job-tech strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .job-accomplishments {
    list-style: none;
    padding: 0;
  }

  .job-accomplishments li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.5rem;
    color: var(--color-text-light);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .job-accomplishments li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 5px;
    height: 5px;
    background: var(--color-sage);
    border-radius: 50%;
  }

  /* Print styles */
  @media print {
    .hero {
      background: white;
      color: black;
      padding: 1rem 0;
    }

    .hero-location,
    .hero-contact a,
    .hero-contact span,
    .hero-subtitle {
      color: #333;
    }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: 5rem 1.25rem 2rem;
    }

    .resume {
      padding-top: 2.5rem;
    }
  }
</style>
