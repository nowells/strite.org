---
const links = [
  { href: 'mailto:nowell@strite.org', label: 'nowell@strite.org' },
  { href: 'https://github.com/nowells', label: 'GitHub' },
  { href: 'https://linkedin.com/in/nowellstrite', label: 'LinkedIn' },
];
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-links">
      {links.map((link, i) => (
        <>
          <a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
            {link.label}
          </a>
          {i < links.length - 1 && <span class="sep">&middot;</span>}
        </>
      ))}
    </div>
    <p class="copyright">&copy; {new Date().getFullYear()} Nowell Strite</p>
  </div>
</footer>

<style>
  .footer {
    padding: 3rem 2rem;
    border-top: 1px solid var(--color-warm-border);
    text-align: center;
  }

  .footer-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .footer-links a {
    color: var(--color-earth);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--color-forest);
  }

  .sep {
    color: var(--color-warm-border);
  }

  .copyright {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
</style>
